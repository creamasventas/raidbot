# ─────────────────────────────────────────────
#  Discord Bot — Environment Variables
#  Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# Required: your bot token from the Discord Developer Portal
DISCORD_TOKEN=your_bot_token_here

# Optional: restrict slash-command sync to one guild for faster dev iteration
# Leave blank to sync globally (can take up to 1 hour to propagate)
GUILD_ID=

# SQLite database path (relative to project root)
DATABASE_PATH=data/bot.db

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ── Twitter / X verification (required for /verify to work) ──────────────────
# Credentials for the X account the bot uses to scrape replies.
# This should be a dedicated bot/scraper account, not your personal one.
TWITTER_EMAIL=scraper@example.com
TWITTER_USERNAME=your_scraper_handle
TWITTER_PASSWORD=your_scraper_password

# Where to save the browser session (cookies persist across restarts)
TWITTER_SESSION_DIR=data/twitter_session

# Run browser headlessly? true = no window (required on servers without a display)
TWITTER_HEADLESS=true

# How many scroll steps to perform when searching for a reply
# More steps = deeper search, but slower. 15 covers ~30-50 replies.
VERIFY_SCROLL_STEPS=15
VERIFY_SCROLL_DELAY_MS=1200

# Set to false to completely disable the /verify, /set-twitter commands
VERIFY_ENABLED=true
